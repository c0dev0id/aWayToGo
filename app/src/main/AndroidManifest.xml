<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:label="aWayToGo"
        android:theme="@style/Theme.App"
        android:supportsRtl="true">

        <activity
            android:name=".map.MapActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Diagnostic activity: raw MapView + Choreographer OSD, zero Compose.
             Launch with:
               adb shell am start -n de.codevoid.aWayToGo/.diagnostic.DiagnosticActivity
             Compare its fps/dt numbers with the OSD in MapActivity to
             determine whether MapActivity itself is introducing overhead. -->
        <activity
            android:name=".diagnostic.DiagnosticActivity"
            android:exported="true" />

    </application>

</manifest>
