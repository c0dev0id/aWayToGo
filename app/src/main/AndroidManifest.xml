<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Required to open the package installer for self-update from GitHub releases. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!-- Required on Android 14+ to maintain GPS access without throttling.
         FOREGROUND_SERVICE_LOCATION gates the foregroundServiceType="location" attribute. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <application
        android:label="aWayToGo"
        android:theme="@style/Theme.App"
        android:supportsRtl="true">

        <activity
            android:name=".map.MapActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Diagnostic: SurfaceView FPS benchmark.
             adb shell am start -n de.codevoid.aWayToGo/.diagnostic.DiagnosticActivity -->
        <activity
            android:name=".diagnostic.DiagnosticActivity"
            android:exported="true" />

        <!-- Diagnostic: intent sniffer for com.thorkracing.wireddevices.* broadcasts.
             adb shell am start -n de.codevoid.aWayToGo/.diagnostic.DiagnosticRemoteActivity -->
        <activity
            android:name=".diagnostic.DiagnosticRemoteActivity"
            android:exported="true" />

        <!-- Diagnostic: screen rotation lifecycle test.
             Shows onCreate / onConfigurationChanged counters to verify that
             configChanges is preventing Activity recreation on rotate.
             adb shell am start -n de.codevoid.aWayToGo/.diagnostic.DiagnosticRotateActivity -->
        <activity
            android:name=".diagnostic.DiagnosticRotateActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden" />

        <!-- Foreground service that holds the FOREGROUND_SERVICE_LOCATION grant.
             Keeps the OS from throttling GPS regardless of power-manager policy. -->
        <service
            android:name=".map.LocationForegroundService"
            android:foregroundServiceType="location"
            android:exported="false" />

        <!-- FileProvider used to share the downloaded update APK with the
             package installer (required on API 24+ for ACTION_VIEW on files). -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
