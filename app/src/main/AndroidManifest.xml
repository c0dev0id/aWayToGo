<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:label="aWayToGo"
        android:theme="@style/Theme.App"
        android:supportsRtl="true">

        <activity
            android:name=".map.MapActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Diagnostic: SurfaceView mode (default).
             adb shell am start -n de.codevoid.aWayToGo/.diagnostic.DiagnosticActivity -->
        <activity
            android:name=".diagnostic.DiagnosticActivity"
            android:exported="true" />

        <!-- Diagnostic: TextureView mode — compare fps/dt with DiagnosticActivity
             to measure whether HWC compositing latency differs on this device.
             adb shell am start -n de.codevoid.aWayToGo/.diagnostic.DiagnosticTextureActivity -->
        <activity
            android:name=".diagnostic.DiagnosticTextureActivity"
            android:exported="true" />

        <!-- Diagnostic: setMaximumFps(30) + setPrefetchZoomDelta(4) — tests
             whether halving the GL render budget reduces tile-load jank.
             adb shell am start -n de.codevoid.aWayToGo/.diagnostic.DiagnosticMaxFpsActivity -->
        <activity
            android:name=".diagnostic.DiagnosticMaxFpsActivity"
            android:exported="true" />

        <!-- Diagnostic: OpenMapTiles maptiler-3d-gl-style (3D building extrusions).
             Style JSON is fetched from GitHub and {key} placeholders are substituted
             at runtime.  Compare fps/dt with DiagnosticActivity (outdoor-v2 baseline).
             adb shell am start -n de.codevoid.aWayToGo/.diagnostic.Diagnostic3dStyleActivity -->
        <activity
            android:name=".diagnostic.Diagnostic3dStyleActivity"
            android:exported="true" />

    </application>

</manifest>
